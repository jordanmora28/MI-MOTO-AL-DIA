<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MotoExpert Colombia - Guía Gratuita</title>
    <style>
        :root { --p: #002855; --s: #ffcd00; --t: #d52b1e; } /* Colores bandera CO */
        body { font-family: sans-serif; background: #f4f4f4; margin: 0; padding: 15px; }
        .card { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        input { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; }
        .sugerencias { border: 1px solid #ddd; border-top: none; max-height: 200px; overflow-y: auto; display: none; }
        .sugerencias div { padding: 10px; border-bottom: 1px solid #eee; cursor: pointer; }
        .sugerencias div:hover { background: #f0f0f0; }
        .guia { display: none; margin-top: 20px; padding: 15px; background: #fffde7; border-left: 5px solid var(--s); }
        .btn-wpp { display: block; text-align: center; background: #25d366; color: white; padding: 12px; text-decoration: none; border-radius: 8px; font-weight: bold; margin-top: 20px; }
    </style>
</head>
<body>

<div class="card">
    <h1 style="color:var(--p); text-align:center;">🇨🇴 MotoExpert</h1>
    <p style="text-align:center;">Mantenimiento fácil para motos en Colombia</p>
    
    <input type="text" id="busqueda" placeholder="Busca tu moto (Ej: NKD, Pulsar...)" onkeyup="buscar()">
    <div id="lista" class="sugerencias"></div>

    <div id="detalle" class="guia">
        <h2 id="m-nombre" style="margin-top:0; color:var(--t);"></h2>
        <p><strong>🛠 Herramientas:</strong> <span id="m-herr"></span></p>
        <p><strong>📦 Repuestos:</strong> <span id="m-rep"></span></p>
        <strong>📋 Pasos:</strong>
        <ul id="m-pasos"></ul>
        
        <a id="wpp" href="#" target="_blank" class="btn-wpp">📲 Cotizar repuestos por WhatsApp</a>
    </div>
</div>

<script>
    // Base de datos inicial (puedes añadir cientos aquí abajo)
    const baseDatos = [
        {m: "AKT NKD 125", h: "Llave 17mm, copa 10mm", r: "Aceite 20W-50 (1L), Bujía CPR7EA", p: ["Drenar aceite en caliente", "Limpiar tamiz", "Calibrar cadena"]},
        {m: "Bajaj Pulsar NS 200", h: "Llave 14mm, extractor filtro", r: "Aceite 20W-50 Sintético, Filtro original", p: ["Cambiar aceite", "Limpiar filtro de aire", "Revisar refrigerante"]},
        {m: "Yamaha NMAX", h: "Llave Allen 5mm, dado 12mm", r: "Aceite 10W-40, Aceite transmisión", p: ["Cambio aceite motor", "Cambio aceite transmisión", "Limpiar filtro variador"]},
        {m: "Suzuki GN 125", h: "Llave 17mm, destornillador", r: "Aceite 20W-50, Filtro de aceite", p: ["Drenar aceite", "Cambiar filtro papel", "Ajustar frenos"]}
    ];

    function buscar() {
        const txt = document.getElementById('busqueda').value.toLowerCase();
        const lista = document.getElementById('lista');
        lista.innerHTML = '';
        if(txt.length < 2) { lista.style.display = 'none'; return; }
        
        const filtrados = baseDatos.filter(i => i.m.toLowerCase().includes(txt));
        if(filtrados.length > 0) {
            lista.style.display = 'block';
            filtrados.forEach(i => {
                const d = document.createElement('div');
                d.textContent = i.m;
                d.onclick = () => mostrar(i);
                lista.appendChild(d);
            });
        }
    }

    function mostrar(i) {
        document.getElementById('lista').style.display = 'none';
        document.getElementById('detalle').style.display = 'block';
        document.getElementById('m-nombre').textContent = i.m;
        document.getElementById('m-herr').textContent = i.h;
        document.getElementById('m-rep').textContent = i.r;
        document.getElementById('m-pasos').innerHTML = i.p.map(p => `<li>${p}</li>`).join('');
        
        // Configura tu WhatsApp (pon tu número real abajo)
        const mensaje = `Hola! Necesito repuestos para mi ${i.m}: ${i.r}`;
        document.getElementById('wpp').href = `https://wa.me/573000000000?text=${encodeURIComponent(mensaje)}`;
    }
</script>
</body>
</html>
